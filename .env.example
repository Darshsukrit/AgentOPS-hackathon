# ============================================================
# AgentOS — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── AI/ML API (primary LLM provider) ────────────────────────
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-3.5-turbo

# ── Featherless API (fallback LLM provider) ─────────────────
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=qwen3-32b

# ── Band Integration ────────────────────────────────────────
BAND_API_KEY=
BAND_BASE_URL=https://app.band.ai/api/v1
BAND_AGENT_ID=
BAND_HANDLE=

# ── Database ────────────────────────────────────────────────
# Required only when DEMO_MODE=false
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=

# ── Redis ───────────────────────────────────────────────────
# Falls back to in-memory state if Redis is unavailable
REDIS_URL=redis://localhost:6379

# ── Application ─────────────────────────────────────────────
# DEMO_MODE=True uses in-memory SQLite — no external DB needed
DEMO_MODE=True
# Backend server port — must match the Vite proxy target in
# frontend/vite.config.ts (default: 8001)
PORT=8001
